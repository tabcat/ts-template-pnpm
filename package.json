{
  "name": "ts-template-pnpm",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "./dist/src"
  ],
  "keywords": [],
  "author": "tabcat",
  "license": "MIT",
  "scripts": {
    "prepublishOnly": "pnpm install && pnpm build",
    "lint": "biome check src test",
    "format": "biome check --write src test",
    "build": "tsc",
    "test": "vitest --config vitest.config.ts --run",
    "test:watch": "vitest --config vitest.config.ts",
    "api-docs": "typedoc src",
    "ci": "pnpm build && pnpm lint && pnpm test"
  },
  "lint-staged": {
    "*.ts": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typedoc": "^0.28.15",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}