{
  "$schema": "https://biomejs.dev/schemas/1.5.3/schema.json",
  "formatter": {
    "enabled": true,
    "lineWidth": 80,
    "indentWidth": 2,
    "ignore": [
      "**/*.json",
      "**/*.md",
      "**/*.yml",
      "**/*.yaml"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "style": {
        "quotes": {
          "level": "error",
          "quoteStyle": "double"
        },
        "semi": "error",
        "useImportType": "fix",
        "useDeclaredVars": "warn"
      },
      "nursery": {
        "organizeImports": "fix"
      }
    }
  }
}